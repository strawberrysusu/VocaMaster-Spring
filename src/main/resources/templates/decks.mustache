<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VocaMaster - 내 단어장</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="container">
    <div class="nav">
        <h1 style="margin:0;">내 단어장</h1>
        <div>
            <span id="user-email" style="font-size:0.85rem;color:#888;"></span>
            <a href="#" onclick="logout()" style="margin-left:12px;">로그아웃</a>
        </div>
    </div>

    <div id="msg" class="msg hidden"></div>

    <!-- 단어장 생성 -->
    <div class="card">
        <div class="form-row">
            <input type="text" id="deck-title" placeholder="새 단어장 이름">
            <button onclick="createDeck()" style="width:auto;min-width:80px;">추가</button>
        </div>
    </div>

    <!-- 단어장 목록 -->
    <div id="deck-list"></div>
</div>

<script>
const TOKEN = localStorage.getItem('token');
if (!TOKEN) window.location.href = '/pages/login';

const headers = {
    'Content-Type': 'application/json',
    'Authorization': 'Bearer ' + TOKEN
};

document.getElementById('user-email').textContent = localStorage.getItem('email') || '';

function showMsg(text, type) {
    const el = document.getElementById('msg');
    el.textContent = text;
    el.className = 'msg ' + type;
    if (type === 'ok') setTimeout(function() { el.className = 'msg hidden'; }, 3000);
}

async function loadDecks() {
    const res = await fetch('/decks', {headers});
    if (res.status === 403 || res.status === 401) { logout(); return; }
    const decks = await res.json();

    const el = document.getElementById('deck-list');
    if (decks.length === 0) {
        el.innerHTML = '<p class="empty-state">단어장이 없습니다. 위에서 추가하세요.</p>';
        return;
    }
    el.innerHTML = decks.map(function(d) {
        return '<div class="card deck-item">' +
            '<div class="deck-info" onclick="location.href=\'/pages/decks/' + d.id + '\'">' +
                '<strong>' + escHtml(d.title) + '</strong>' +
                ' <span class="badge">' + d.cardCount + '장</span>' +
                (d.description ? '<p style="color:#888;font-size:0.85rem;margin-top:4px;">' + escHtml(d.description) + '</p>' : '') +
            '</div>' +
            '<button class="deck-delete" onclick="event.stopPropagation();deleteDeck(' + d.id + ',\'' + escJs(d.title) + '\')" title="삭제">&times;</button>' +
        '</div>';
    }).join('');
}

async function createDeck() {
    const title = document.getElementById('deck-title').value.trim();
    if (!title) { showMsg('단어장 이름을 입력하세요', 'error'); return; }
    const res = await fetch('/decks', {method:'POST', headers, body: JSON.stringify({title:title})});
    if (!res.ok) { const d = await res.json(); showMsg(d.message || '생성 실패', 'error'); return; }
    showMsg('단어장 생성 완료', 'ok');
    document.getElementById('deck-title').value = '';
    loadDecks();
}

async function deleteDeck(id, title) {
    if (!confirm('"' + title + '" 단어장을 삭제할까요?\n포함된 카드도 모두 삭제됩니다.')) return;
    const res = await fetch('/decks/' + id, {method:'DELETE', headers});
    if (!res.ok) { showMsg('삭제 실패', 'error'); return; }
    showMsg('삭제 완료', 'ok');
    loadDecks();
}

function logout() {
    localStorage.removeItem('token');
    localStorage.removeItem('email');
    window.location.href = '/pages/login';
}

function escHtml(s) {
    var div = document.createElement('div');
    div.textContent = s;
    return div.innerHTML;
}
function escJs(s) { return s.replace(/\\/g,'\\\\').replace(/'/g,"\\'"); }

document.getElementById('deck-title').addEventListener('keydown', function(e) {
    if (e.key === 'Enter') createDeck();
});

loadDecks();
</script>
</body>
</html>
