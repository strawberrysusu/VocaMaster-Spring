# 운영(prod) profile 실행 시 필요한 환경변수.
# 이 파일은 안내용 템플릿입니다. 실제 값은 .env로 복사해서 채우거나,
# 운영 서버/배포 환경(EC2, Docker, GitHub Actions 등)에 직접 등록하세요.
# .env 파일은 .gitignore에 등록되어 있어 커밋되지 않습니다.

# Spring profile 활성화 (운영 환경에서 prod로 지정)
SPRING_PROFILES_ACTIVE=prod

# Database
DB_URL=jdbc:mysql://your-db-host:3306/vocamaster?useSSL=false&serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME=vocamaster_user
DB_PASSWORD=your-strong-password

# JWT (32자 이상 권장)
JWT_SECRET=replace-with-strong-random-string-minimum-32-chars
